# Google AI Studio API key (free tier, no credit card required)
# Required always -- Gemini handles embeddings regardless of which chat provider is primary,
# and serves as the chat fallback when ANTHROPIC_API_KEY is set.
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Web search: DuckDuckGo via the `ddgs` package (see retrieval/web_search.py). No API key,
# signup, or billing account required -- unlike Google Custom Search (which gates even its
# free tier behind a linked billing account) or Brave/Tavily (paid). Nothing to configure here.

# Anthropic API key. This line must exist (config validation fails fast if it's absent
# entirely), but the value itself may be left blank. When set, Claude becomes the primary
# chat/reasoning model for routing, decomposition, grading, and synthesis, with automatic
# fallback to Gemini on error. Left blank, Gemini is used for everything, as before.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# App environment: development | staging | production
APP_ENV=development
LOG_LEVEL=INFO

# Redis (caches router decisions, web search results, and synthesized answers -- see cache.py).
# Set USE_CACHE=false to disable outright (tests do this automatically).
REDIS_URL=redis://localhost:6379/0
USE_CACHE=true
CACHE_TTL_ROUTER=300
CACHE_TTL_WEB_SEARCH=600
CACHE_TTL_SYNTHESIS=1800

# Rate limiting (requests/minute)
RATE_LIMIT_RPM=10
RATE_LIMIT_RPM_GLOBAL=30

# Request timeouts (seconds)
WEB_SEARCH_TIMEOUT_SECONDS=10
GRAPH_TIMEOUT_SECONDS=45
# Per-attempt LLM timeout + retry cap. Keeps a slow/rate-limited provider from silently
# retrying with backoff for tens of seconds (Gemini defaults to 6 retries) and starving the
# rest of the graph's GRAPH_TIMEOUT_SECONDS budget.
LLM_REQUEST_TIMEOUT_SECONDS=12
LLM_MAX_RETRIES=1

# Optional overrides — defaults shown
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
# ANTHROPIC_CHAT_MODEL=claude-sonnet-5
